# ─────────────────────────────────────────────────────────────
# Krishi AI — Environment Variables
# Copy this file to .env.local for local development.
# In Vercel: add these under Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# PRIMARY — Google Gemini 2.0 Flash (free tier available)
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# FALLBACK — OpenRouter (Gemini 1.5 Flash via OpenRouter)
# Get key at: https://openrouter.ai/keys
# Only needed if Gemini primary fails
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ─────────────────────────────────────────────────────────────
# NOTES
# • Both keys are server-side only (used in api/analyze.js)
# • Never expose these in src/ or any client-side code
# • The app works without any keys (rule-based fallback active)
# ─────────────────────────────────────────────────────────────
